# ir-playbooks-automation — Environment Configuration Template
# ================================================================
# Copy this file to .env and fill in values appropriate for your environment.
# Never commit .env to version control — it is listed in .gitignore.
#
# All variables here have safe defaults suitable for dry-run/testing use.

# Default incident type applied when opening a new incident without --type
# Options: generic, credential_compromise, malware, data_exposure, api_abuse,
#          phishing, cloud_exposure, secret_leakage
INCIDENT_TYPE=generic

# Severity classification model to use when auto-scoring alerts
# Options: standard (NIST-aligned), cvss, custom
SEVERITY_MODEL=standard

# Local directory where evidence packages will be written
EVIDENCE_DIR=./evidence

# Automatically generate a timeline skeleton when a new incident is opened
AUTO_GENERATE_TIMELINE=true

# Send notifications to external channels (Slack, PagerDuty) on state transitions
# Set to true only after configuring notification credentials in .env
NOTIFICATION_ENABLED=false

# When true, executive_brief.md template is used for report generation
# and sensitive technical details are omitted from output
EXECUTIVE_SUMMARY_MODE=false

# Safe automation mode: all automation scripts default to dry_run=True
# Set to false only in production with approval controls in place
SAFE_AUTOMATION_MODE=true

# Mask potentially sensitive values (IPs, usernames, tokens) in log output and reports
# Recommended: true in all environments
MASKING_MODE=true

# Controls report detail level
# Options: minimal (executive), standard (analyst), verbose (full forensic)
REPORT_VERBOSITY=standard

# Require explicit operator approval before executing containment automations
# Strongly recommended: true. Set to false only in fully automated runbook environments
# with a compensating approval workflow outside this tool.
APPROVAL_REQUIRED_FOR_CONTAINMENT=true
